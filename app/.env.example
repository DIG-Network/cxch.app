# WalletConnect Cloud project id (https://cloud.walletconnect.com).
NEXT_PUBLIC_WC_PROJECT_ID=

# The canonical cXCH asset id (TAIL hash). This is deterministic and baked into
# the WASM module; it is provided here for display and coin-selection. Recompute
# with `cargo run --example identity` inside ../cxch-core.
NEXT_PUBLIC_CXCH_ASSET_ID=0x8808ca01803e09bf6d067075c9373b227aa8b086504ff0ac63cb3f02fe21c9ba

# Coinset.org mainnet REST base URL used to broadcast spend bundles.
NEXT_PUBLIC_COINSET_API=https://api.coinset.org

# Default network fee in mojos (0.0001 XCH).
NEXT_PUBLIC_DEFAULT_FEE_MOJOS=100000000

# cXCH is mainnet-only; the chain id (chia:mainnet) is fixed in code.
