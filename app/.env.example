# WalletConnect Cloud project id (https://cloud.walletconnect.com).
NEXT_PUBLIC_WC_PROJECT_ID=

# Coinset.org mainnet REST base URL used to broadcast spend bundles.
NEXT_PUBLIC_COINSET_API=https://api.coinset.org

# Default network fee in mojos (0.0001 XCH).
NEXT_PUBLIC_DEFAULT_FEE_MOJOS=100000000

# cMojo is mainnet-only; the chain id (chia:mainnet) is fixed in code.
